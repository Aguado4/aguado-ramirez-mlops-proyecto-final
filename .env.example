# Copia este archivo a .env y completa los valores.
# En GitHub Actions estos valores vienen de Secrets/Variables del repo.

# Bucket GCS donde viven el modelo, los datos de prueba y los logs de predicciones
GCS_BUCKET=mlops-proyecto-artifacts

# Ruta del modelo ONNX dentro del bucket (NO se versiona en git)
MODEL_BLOB=models/iris.onnx

# Ruta de los datos de prueba dentro del bucket
TEST_DATA_BLOB=data/iris_test.csv

# Entorno actual: dev o prod (define a qué archivo de log se escribe)
ENVIRONMENT=dev

# Archivos de log de predicciones por entorno (dentro del bucket)
PRED_LOG_DEV=predicciones_dev.txt
PRED_LOG_PROD=predicciones_prod.txt

# Umbral mínimo de accuracy que el modelo debe superar en la etapa de test
ACCURACY_THRESHOLD=0.85
